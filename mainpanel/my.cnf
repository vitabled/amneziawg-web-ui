[client]
default-character-set = utf8mb4

[mysql]
default-character-set = utf8mb4

[mysqld]
# --- Кодировка (оставляем как было) ---
character-set-server = utf8mb4
collation-server = utf8mb4_unicode_ci
init_connect = 'SET NAMES utf8mb4 COLLATE utf8mb4_unicode_ci'
skip-character-set-client-handshake

# --- Оптимизация памяти ---
# Главный буфер InnoDB (было ~128M по умолчанию)
innodb_buffer_pool_size = 32M
innodb_buffer_pool_instances = 1

# Буфер лога транзакций
innodb_log_buffer_size = 4M

# Отключить performance_schema (~50-80MB экономии)
performance_schema = OFF

# Соединения (для админ-панели хватит с запасом)
max_connections = 20
thread_cache_size = 4

# Буферы сортировки/джойнов (на поток, не глобально)
sort_buffer_size = 512K
join_buffer_size = 512K
read_buffer_size = 512K
read_rnd_buffer_size = 256K

# Временные таблицы в памяти
tmp_table_size = 16M
max_heap_table_size = 16M

# Кэш таблиц
table_open_cache = 64
table_definition_cache = 64